---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Nosotros from '../components/Nosotros.astro';
import WAFloatingButton from '../components/WAFloatingButton.astro';
import Beneficios from '../components/Beneficios.astro';
import Proceso from '../components/Proceso.astro';
import Clientes from '../components/Clientes.astro';
import FAQ from '../components/FAQ.astro';

// Aquí irás agregando los demás componentes conforme los construyas:
// import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <main class="main-content">
    <Hero />
    <Servicios />
    <Nosotros />
    <Beneficios />
    <Proceso />
    <Clientes />
    <FAQ />
    <!-- <CTAFinal /> -->
  </main>
  <Footer />
  <WAFloatingButton />
</Layout>

<style>
  .main-content {
    padding-top: 80px; /* Altura del header fijo (16px padding top + 48px logo + 16px padding bottom) */
  }

  @media (max-width: 639px) {
    .main-content {
      padding-top: 64px; /* Altura del header en móvil (12px padding top + 40px logo + 12px padding bottom) */
    }
  }
</style>
