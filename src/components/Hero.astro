---
// src/components/Hero.astro
const WA_NUMBER = "51939686476"; // 
const WA_MSG_DEFAULT = encodeURIComponent("Hola, vi su página web y quisiera solicitar una cotización.");
const waLink = `https://wa.me/${WA_NUMBER}?text=${WA_MSG_DEFAULT}`;
---

<section class="hero" id="inicio" aria-label="Presentación del servicio">
  <!-- Textura de fondo (elemento firma: trama sutil de brocha) -->
  <div class="hero-texture" aria-hidden="true"></div>

  <div class="container">
    <div class="hero-content">

      <!-- Badge de confianza -->
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Atendemos hoy en Lima Metropolitana
      </div>

      <!-- Titular principal (H1 — solo uno en toda la página) -->
      <h1 class="hero-title">
        Mantenimiento profesional<br>
        para tu <span class="title-accent">hogar o empresa</span>
      </h1>

      <p class="hero-subtitle">
        Pintura · Gasfitería · Electricidad · Soldadura · Remodelaciones<br>
        Respondemos en <strong>menos de 2 horas</strong>. Presupuesto sin costo.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas">
        <a
          href={waLink}
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          data-gtm-event="whatsapp_click"
          data-gtm-source="hero"
          aria-label="Cotizar por WhatsApp"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.374 0 0 5.373 0 12c0 2.108.555 4.105 1.528 5.843L.057 23.997l6.304-1.654C8.052 23.392 9.987 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.6c-1.82 0-3.59-.507-5.115-1.466l-.366-.218-3.793.994.999-3.688-.237-.382A9.569 9.569 0 012.4 12c0-5.302 4.298-9.6 9.6-9.6S21.6 6.698 21.6 12s-4.298 9.6-9.6 9.6z"/>
          </svg>
          Cotizar por WhatsApp
        </a>

        <a href="#servicios" class="btn-secondary">
          Ver servicios ↓
        </a>
      </div>

      <!-- Stats de confianza -->
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-number" data-target="500">0</span>
          <span class="stat-plus">+</span>
          <span class="stat-label">Trabajos realizados</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-number" data-target="8">0</span>
          <span class="stat-plus">+</span>
          <span class="stat-label">Años de experiencia</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-number" data-target="2">0</span>
          <span class="stat-suffix">h</span>
          <span class="stat-label">Respuesta garantizada</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: #0E2147;
    background-image: radial-gradient(ellipse at 80% 20%, #1B3A6B 0%, #0E2147 60%);
    padding: 80px 0 64px;
    overflow: hidden;
  }

  /* Textura firma: trama sutil de líneas diagonales */
  .hero-texture {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: repeating-linear-gradient(
      45deg,
      #fff 0px,
      #fff 1px,
      transparent 1px,
      transparent 12px
    );
    pointer-events: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  .hero-content { max-width: 680px; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(245, 166, 35, 0.15);
    border: 1px solid rgba(245, 166, 35, 0.3);
    color: #F5A623;
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 20px;
    margin-bottom: 24px;
  }
  .badge-dot {
    width: 7px; height: 7px;
    background: #10B981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    color: #FFFFFF;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
  }
  .title-accent { color: #F5A623; }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #93AECF;
    line-height: 1.7;
    margin: 0 0 32px;
  }
  .hero-subtitle strong { color: #FFFFFF; }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #F5A623;
    color: #412402;
    font-size: 16px;
    font-weight: 700;
    padding: 14px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 20px rgba(245, 166, 35, 0.35);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(245, 166, 35, 0.45);
  }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    color: #93AECF;
    font-size: 15px;
    font-weight: 500;
    padding: 14px 20px;
    border-radius: 10px;
    border: 1px solid rgba(147, 174, 207, 0.3);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-secondary:hover { border-color: #93AECF; color: #FFFFFF; }

  /* Stats */
  .hero-stats {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }
  .stat-item {
    display: flex;
    align-items: baseline;
    gap: 2px;
    padding: 0 32px 0 0;
    flex-shrink: 0;
  }
  .stat-number {
    font-size: 2rem;
    font-weight: 800;
    color: #F5A623;
  }
  .stat-plus, .stat-suffix {
    font-size: 1.25rem;
    font-weight: 700;
    color: #F5A623;
    margin-right: 8px;
  }
  .stat-label {
    font-size: 12px;
    color: #6B90B5;
    align-self: center;
    padding-top: 4px;
  }
  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.1);
    margin: 0 32px 0 0;
    align-self: center;
  }

  /* Responsive mobile */
  @media (max-width: 640px) {
    .hero { padding: 60px 0 48px; }
    .hero-stats { gap: 16px; }
    .stat-item { padding: 0; }
    .stat-divider { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-dot { animation: none; }
  }
</style>

<script>
  // Animación de contadores al entrar en viewport
  const counters = document.querySelectorAll('.stat-number');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target ?? '0', 10);
      const duration = 1500;
      const start = performance.now();
      const animate = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
        el.textContent = Math.round(eased * target).toString();
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
      observer.unobserve(el);
    });
  }, { threshold: 0.5 });

  counters.forEach(c => observer.observe(c));

  // Tracking GTM para clicks a WhatsApp
  document.querySelectorAll('[data-gtm-event="whatsapp_click"]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (typeof window !== 'undefined' && (window as any).dataLayer) {
        (window as any).dataLayer.push({
          event: 'whatsapp_click',
          whatsapp_source: btn.getAttribute('data-gtm-source') ?? 'unknown'
        });
      }
    });
  });
</script>
