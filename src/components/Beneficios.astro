---
// src/components/Beneficios.astro
const WA_NUMBER = "51939686476";

const beneficios = [
  {
    icono: "📋",
    titulo: "Presupuesto sin costo",
    descripcion: "Te enviamos el precio exacto antes de empezar. Sin cargos ocultos ni sorpresas.",
  },
  {
    icono: "⚡",
    titulo: "Respuesta en 2 horas",
    descripcion: "Te respondemos en menos de 2 horas hábiles. Urgencias el mismo día.",
  },
  {
    icono: "🛡️",
    titulo: "Trabajo con garantía",
    descripcion: "Todos nuestros servicios están garantizados. Si algo no queda bien, lo corregimos.",
  },
  {
    icono: "📍",
    titulo: "Cobertura en Lima",
    descripcion: "Atendemos en Miraflores, San Isidro, Surco, La Molina, San Borja y más distritos.",
  },
  {
    icono: "🤝",
    titulo: "Un solo proveedor",
    descripcion: "Pintura, gasfitería, electricidad, soldadura y más. Un solo equipo, un solo contacto.",
  },
  {
    icono: "🏆",
    titulo: "Experiencia comprobada",
    descripcion: "Más de 8 años y 500+ trabajos realizados en hogares, edificios y empresas.",
  },
];
---

<section class="beneficios" id="beneficios" aria-label="Beneficios de trabajar con nosotros">
  <div class="container">
    <div class="section-header">
      <p class="section-eyebrow">Por qué elegirnos</p>
      <h2 class="section-title">Beneficios que marcan la diferencia</h2>
      <p class="section-subtitle">
        No solo hacemos el trabajo. Te damos tranquilidad, transparencia y respaldo.
      </p>
    </div>

    <div class="beneficios-grid">
      {beneficios.map((b) => (
        <article class="beneficio-card">
          <div class="beneficio-icon" aria-hidden="true">{b.icono}</div>
          <div class="beneficio-content">
            <h3 class="beneficio-titulo">{b.titulo}</h3>
            <p class="beneficio-desc">{b.descripcion}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="beneficios-cta">
      <a
        href={`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent("Hola, vi los beneficios de su página y quisiera solicitar una cotización.")}`}
        class="btn-primary"
        target="_blank"
        rel="noopener noreferrer"
        data-gtm-event="whatsapp_click"
        data-gtm-source="beneficios"
        aria-label="Solicitar cotización"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.374 0 0 5.373 0 12c0 2.108.555 4.105 1.528 5.843L.057 23.997l6.304-1.654C8.052 23.392 9.987 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.6c-1.82 0-3.59-.507-5.115-1.466l-.366-.218-3.793.994.999-3.688-.237-.382A9.569 9.569 0 012.4 12c0-5.302 4.298-9.6 9.6-9.6S21.6 6.698 21.6 12s-4.298 9.6-9.6 9.6z"/>
        </svg>
        Solicitar cotización gratis
      </a>
    </div>
  </div>
</section>

<style>
  .beneficios {
    padding: 80px 0;
    background: #FFFFFF;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F5A623;
    margin: 0 0 12px;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: #111827;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: #6B7280;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .beneficios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .beneficio-card {
    display: flex;
    gap: 18px;
    padding: 24px;
    background: #F7F8FA;
    border-radius: 14px;
    border: 1px solid #E5E7EB;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .beneficio-card:hover {
    border-color: #1B3A6B;
    box-shadow: 0 6px 24px rgba(27, 58, 107, 0.08);
    transform: translateY(-2px);
  }

  .beneficio-icon {
    font-size: 2rem;
    flex-shrink: 0;
    display: flex;
    align-items: flex-start;
    padding-top: 2px;
  }

  .beneficio-content {
    flex: 1;
  }

  .beneficio-titulo {
    font-size: 1.05rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 6px;
  }

  .beneficio-desc {
    font-size: 0.92rem;
    color: #6B7280;
    line-height: 1.6;
    margin: 0;
  }

  .beneficios-cta {
    text-align: center;
    margin-top: 48px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #F5A623;
    color: #412402;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 20px rgba(245, 166, 35, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(245, 166, 35, 0.4);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .beneficios { padding: 56px 0; }
    .beneficios-grid { gap: 16px; }
    .beneficio-card { padding: 18px; gap: 14px; }
    .beneficio-icon { font-size: 1.6rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .beneficio-card:hover { transform: none; }
    .btn-primary:hover { transform: none; }
  }
</style>

<script>
  // Tracking GTM para clicks al CTA
  document.querySelector('[data-gtm-event="whatsapp_click"]')?.addEventListener('click', () => {
    if (typeof window !== 'undefined' && (window as any).dataLayer) {
      (window as any).dataLayer.push({
        event: 'whatsapp_click',
        whatsapp_source: 'beneficios'
      });
    }
  });
</script>